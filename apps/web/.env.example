# MapTiler — free at https://cloud.maptiler.com/account/keys/
NEXT_PUBLIC_MAPTILER_API_KEY=your_key_here

# Google Places API — server-side only (for photo proxy + enrichment script)
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable: "Places API (New)" + "Maps Embed API" on your project
GOOGLE_PLACES_API_KEY=your_key_here

# Same Google key, but exposed to the client for Maps Embed (Street View iframe).
# Maps Embed API is free and domain-restricted — safe to expose.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your_key_here
